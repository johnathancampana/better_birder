# Supabase
NEXT_PUBLIC_SUPABASE_URL=your-supabase-url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key

# eBird API
EBIRD_API_KEY=your-ebird-api-key

# Anthropic Claude API
ANTHROPIC_API_KEY=your-anthropic-api-key

# BirdNET server (run: python -m birdnet_analyzer.server --host localhost --port 8080)
BIRDNET_SERVER_URL=http://localhost:8080/analyze

# VAPID keys for push notifications (generate with: npx web-push generate-vapid-keys)
NEXT_PUBLIC_VAPID_PUBLIC_KEY=your-vapid-public-key
VAPID_PRIVATE_KEY=your-vapid-private-key
